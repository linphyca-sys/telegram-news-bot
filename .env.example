# ── 필수 ─────────────────────────────────────────
# BotFather(@BotFather)에서 봇 생성 후 받은 토큰
TELEGRAM_BOT_TOKEN=

# 뉴스를 받을 채팅 ID (get_chat_id.py로 확인)
TELEGRAM_CHAT_ID=

# 검색할 키워드 (쉼표로 구분)
KEYWORDS=동료지원인,장애인복지

# ── 선택 ─────────────────────────────────────────
# 검색 주기 (분 단위, 기본 5)
INTERVAL_MINUTES=5

# 1회 검색당 키워드별 최대 전송 기사 수 (0 = 무제한)
MAX_PER_KEYWORD=0

# 최초 실행 시 키워드별로 보여줄 최신 기사 수 (기본 3)
FIRST_RUN_SEND=3

# 발행 후 이 시간(시간 단위)이 지난 기사는 전송하지 않음 (기본 6)
MAX_AGE_HOURS=6

# 네이버 뉴스 검색 API 키 (있으면 네이버, 없으면 구글 뉴스 RSS 사용)
# https://developers.naver.com/apps 에서 애플리케이션 등록 → "검색" API 선택
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
